{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/hooks/route-edit.ps1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__codecgc__*",
      "mcp__codex__*",
      "mcp__gemini__*"
    ]
  }
}
